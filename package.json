{
  "name": "scout-shob-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "שו\"ב צופים — Mobile app wrapper for the static PWA in scout/",
  "scripts": {
    "init:capacitor": "npx cap init 'שו\"ב צופים' org.tzofim.shob --web-dir=scout",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "sync": "npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "build": "npx cap sync && echo '✓ web assets synced into ios/ and android/'"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  }
}
