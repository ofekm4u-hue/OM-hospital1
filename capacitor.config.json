{
  "appId": "org.tzofim.shob",
  "appName": "שו״ב צופים",
  "webDir": "scout",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "always",
    "scrollEnabled": true,
    "backgroundColor": "#0A0E14"
  },
  "android": {
    "backgroundColor": "#0A0E14",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0A0E14",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "iosSpinnerStyle": "small",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "backgroundColor": "#0A0E14",
      "style": "DARK"
    }
  }
}
