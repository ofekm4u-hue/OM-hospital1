# ── LLBG ATC — environment configuration ────────────────────────────────────
# Copy this file to ".env" and fill in ONE provider key. With no key, the server
# automatically uses the built-in offline rule-based Hebrew pilot.

# Choose: openai | anthropic | auto | offline   (auto picks whichever key exists)
LLM_PROVIDER=auto

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
